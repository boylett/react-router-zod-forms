{
  "name": "react-router-zod-forms",
  "version": "1.2.2",
  "description": "Forms management for React Router 7 applications using Zod 4 for validation and schemas",
  "author": "boylett <ryan@boylett.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boylett/react-router-zod-forms.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./server": {
      "default": "./dist/server.js"
    },
    "./types": {
      "types": "./dist/types.d.js"
    }
  },
  "scripts": {
    "build": "rm -rf ./dist && tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json"
  },
  "peerDependencies": {
    "@mjackson/form-data-parser": "^0.9.0",
    "@mjackson/multipart-parser": "^0.10.0",
    "luxon": "^3.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "type-fest": "^5.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@mjackson/form-data-parser": "^0.9.1",
    "@mjackson/multipart-parser": "^0.10.1",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/luxon": "^3.7.1",
    "@types/react": "^19.2.14",
    "luxon": "^3.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.2",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  }
}
